# Copy this file to .env and fill in values (especially API_BASE_URL).
# Never commit .env to version control.
#
# Paths below align with docs/valet-master-api.html (prefix /api/v1).

# Base URL — no trailing slash
API_BASE_URL=http://localhost:8000

# Optional request body for POST /device/register when prefs are empty.
# Leave unset or empty; branch/area come from the API response after the device is assigned in admin.
# DEVICE_BRANCH=
# DEVICE_AREA=

# Temporary dev: after splash, insert `device_info` for the real device id (from DeviceIdService) if missing/empty.
# Defaults on in `flutter run` (debug); set to false to test "not assigned". Release: off unless true.
# DEV_SEED_DEVICE_SITE=true
# DEV_SEED_BRANCH=Ayala Circuit
# DEV_SEED_AREA=Area B

# ── AUTH & DEVICE ─────────────────────────
API_DEVICE_REGISTER=/api/v1/device/register
API_AUTH_LOGIN=/api/v1/auth/login
API_AUTH_VALIDATE_TOKEN=/api/v1/auth/validate-token
API_AUTH_LOGOUT=/api/v1/auth/logout
API_DEVICES_ACTIVE=/api/v1/devices/active
API_DEVICES_CLAIM=/api/v1/devices/claim

# ── CASH SESSIONS (POS shift) ──────────────
API_CASH_SESSIONS_START=/api/v1/cash-sessions/start
API_CASH_SESSIONS_CLOSE=/api/v1/cash-sessions/close
API_CASH_SESSION_CURRENT=/api/v1/cash-sessions/current

# Legacy shift URLs (optional; app prefers cash-sessions when unset)
# API_SHIFT_OPEN=/api/v1/shifts/open
# API_SHIFT_CLOSE=/api/v1/shifts/close
# API_SHIFT_CURRENT=/api/v1/shifts/current

# ── TRANSACTIONS & TICKETS ────────────────
API_TICKETS_REST=/api/v1/transactions
API_TICKET_CREATE=/api/v1/transactions
API_TICKET_BY_ID=/api/v1/transactions/{id}
API_TRANSACTION_GET=/api/v1/transactions/{id}
API_TRANSACTION_PAY=/api/v1/transactions/{id}/pay
API_TICKET_CHECKOUT=/api/v1/transactions/{ticket_id}
API_TICKET_BY_NUMBER=/api/v1/tickets/by-number/{ticket_number}
API_TICKET_LOST=/api/v1/tickets/{ticket_id}/lost
API_TICKET_SCAN=/api/v1/tickets/scan
API_TICKET_GET=/api/v1/tickets/{ticket_number}
API_TRANSACTIONS=/api/v1/transactions

# ── BRANCHES & RATES ───────────────────────
API_BRANCH_DETAIL=/api/v1/branches/{branch_id}
API_BRANCH_STANDARD_RATES=/api/v1/branches/{branch_id}/rates
API_BRANCH_RATES=/api/v1/rates/branches/{branch_id}
API_BRANCH_VEHICLE_TYPE_RATES=/api/v1/rates/branches/{branch_id}/vehicle-types

# ── SETTINGS ──────────────────────────────
API_CONFIG=/api/v1/settings

# ── REPORTS (not listed in valet-master-api.html; adjust if backend differs)
API_REPORTS_SALES=/api/v1/reports/summary
API_REPORTS_SHIFTS=/api/v1/reports/shifts
