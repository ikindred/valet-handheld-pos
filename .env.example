# Copy this file to .env and fill in values
# Never commit .env to version control

API_BASE_URL=http://localhost:8000

# Optional request body for POST /device/register when prefs are empty.
# Leave unset or empty; branch/area come from the API response after the device is assigned in admin.
# DEVICE_BRANCH=
# DEVICE_AREA=

# Temporary dev: after splash, insert `device_info` for the real device id (from DeviceIdService) if missing/empty.
# Defaults on in `flutter run` (debug); set to false to test "not assigned". Release: off unless true.
# DEV_SEED_DEVICE_SITE=true
# DEV_SEED_BRANCH=Ayala Circuit
# DEV_SEED_AREA=Area B

API_DEVICE_REGISTER=/api/v1/device/register
API_AUTH_LOGIN=/api/v1/auth/login
API_AUTH_VALIDATE_TOKEN=/api/v1/auth/validate-token
API_AUTH_LOGOUT=/api/v1/auth/logout

API_SHIFT_OPEN=/api/v1/shifts/open
API_SHIFT_CLOSE=/api/v1/shifts/close
API_SHIFT_CURRENT=/api/v1/shifts/current

API_TICKET_CREATE=/api/v1/tickets
API_TICKET_SCAN=/api/v1/tickets/scan
API_TICKET_CHECKOUT=/api/v1/tickets/{ticket_id}/checkout
API_TICKET_LOST=/api/v1/tickets/{ticket_id}/lost
API_TICKET_GET=/api/v1/tickets/{ticket_number}

API_CONFIG=/api/v1/config

API_REPORTS_SALES=/api/v1/reports/sales
API_REPORTS_SHIFTS=/api/v1/reports/shifts

API_SYNC_FLUSH=/api/v1/sync/flush
